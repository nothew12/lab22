<Window x:Class="WpfTextEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Текстовий Редактор" Height="600" Width="900"
        MinHeight="400" MinWidth="600">

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed"/>
    </Window.CommandBindings>

    <DockPanel>

        <!-- ═══ TOOLBAR ═══ -->
        <ToolBarTray DockPanel.Dock="Top" Background="#F0F0F0">
            <ToolBar Band="1" BandIndex="1">

                <!-- Файл -->
                <Button Command="ApplicationCommands.Open" ToolTip="Відкрити (Ctrl+O)">
                    <TextBlock Text="📂" FontSize="16"/>
                </Button>
                <Button Command="ApplicationCommands.Save" ToolTip="Зберегти (Ctrl+S)">
                    <TextBlock Text="💾" FontSize="16"/>
                </Button>

                <Separator/>

                <!-- Форматування -->
                <ToggleButton Command="EditingCommands.ToggleBold"   Name="btnBold"
                              ToolTip="Жирний (Ctrl+B)" Width="28" Height="28">
                    <TextBlock Text="B" FontWeight="Bold" FontSize="14"/>
                </ToggleButton>
                <ToggleButton Command="EditingCommands.ToggleItalic" Name="btnItalic"
                              ToolTip="Курсив (Ctrl+I)" Width="28" Height="28">
                    <TextBlock Text="I" FontStyle="Italic" FontSize="14"/>
                </ToggleButton>
                <ToggleButton Command="EditingCommands.ToggleUnderline" Name="btnUnderline"
                              ToolTip="Підкреслений (Ctrl+U)" Width="28" Height="28">
                    <TextBlock FontSize="14">
                        <Underline>U</Underline>
                    </TextBlock>
                </ToggleButton>

                <Separator/>

                <!-- Вирівнювання -->
                <ToggleButton Name="btnAlignLeft"   Click="AlignLeft_Click"   ToolTip="По лівому краю"  Width="28" Height="28">
                    <TextBlock Text="◀" FontSize="12"/>
                </ToggleButton>
                <ToggleButton Name="btnAlignCenter" Click="AlignCenter_Click" ToolTip="По центру"       Width="28" Height="28">
                    <TextBlock Text="≡" FontSize="12"/>
                </ToggleButton>
                <ToggleButton Name="btnAlignRight"  Click="AlignRight_Click"  ToolTip="По правому краю" Width="28" Height="28">
                    <TextBlock Text="▶" FontSize="12"/>
                </ToggleButton>

                <Separator/>

                <!-- Шрифт -->
                <ComboBox Name="cmbFontFamily" Width="150"
                          SelectionChanged="cmbFontFamily_SelectionChanged"
                          ToolTip="Сімейство шрифту"/>
                <ComboBox Name="cmbFontSize" Width="55" IsEditable="True"
                          TextBoxBase.TextChanged="cmbFontSize_TextChanged"
                          ToolTip="Розмір шрифту"/>

                <Separator/>

                <!-- Колір тексту -->
                <Button Click="ColorPicker_Click" ToolTip="Колір тексту" Width="28" Height="28">
                    <TextBlock Text="🎨" FontSize="14"/>
                </Button>

                <Separator/>

                <!-- Мова -->
                <ComboBox Name="cmbLanguage" Width="110"
                          SelectionChanged="cmbLanguage_SelectionChanged"
                          ToolTip="Мова інтерфейсу">
                    <ComboBoxItem Tag="uk" IsSelected="True">🇺🇦 Українська</ComboBoxItem>
                    <ComboBoxItem Tag="en">🇬🇧 English</ComboBoxItem>
                    <ComboBoxItem Tag="pl">🇵🇱 Polski</ComboBoxItem>
                </ComboBox>

            </ToolBar>
        </ToolBarTray>

        <!-- ═══ STATUS BAR ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E8E8E8">
            <StatusBarItem>
                <TextBlock Name="tbStatus" Text="Готово"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Name="tbWordCount" Text="Слів: 0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ EDITOR ═══ -->
        <RichTextBox Name="rtbEditor"
                     SelectionChanged="rtbEditor_SelectionChanged"
                     TextChanged="rtbEditor_TextChanged"
                     AcceptsTab="True"
                     SpellCheck.IsEnabled="True"
                     FontSize="14"
                     Padding="10"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto">
            <FlowDocument>
                <Paragraph>
                    <Run></Run>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>

    </DockPanel>
</Window>
